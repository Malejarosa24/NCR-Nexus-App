<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo">

    <!-- Logo -->

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="220dp"
        android:layout_height="90dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Título -->

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nueva Solicitud"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="22sp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tarjeta -->

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFormulario"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Cliente -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cliente"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre del cliente"
                    android:background="@drawable/input_field_bg"
                    android:padding="12dp"
                    android:layout_marginTop="6dp"/>

                <!-- Empresa -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Empresa"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"/>

                <EditText
                    android:id="@+id/etEmpresa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Empresa"
                    android:background="@drawable/input_field_bg"
                    android:padding="12dp"
                    android:layout_marginTop="6dp"/>

                <!-- Asunto -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Asunto"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"/>

                <EditText
                    android:id="@+id/etAsunto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Asunto de la solicitud"
                    android:background="@drawable/input_field_bg"
                    android:padding="12dp"
                    android:layout_marginTop="6dp"/>

                <!-- Descripción -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descripción"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"/>

                <EditText
                    android:id="@+id/etDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="top|start"
                    android:hint="Describe la solicitud..."
                    android:background="@drawable/input_field_bg"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:maxLines="6"
                    android:layout_marginTop="6dp"/>

                <!-- Botón guardar -->

                <Button
                    android:id="@+id/btnGuardarSolicitud"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Guardar Solicitud"
                    android:textAllCaps="false"
                    android:backgroundTint="#333333"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="24dp"/>

                <!-- Botón volver -->

                <Button
                    android:id="@+id/btnVolver"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Volver"
                    android:textAllCaps="false"
                    android:backgroundTint="#777777"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </ScrollView>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>